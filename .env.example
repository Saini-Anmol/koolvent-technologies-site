# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit real keys.

# Web3Forms access key — powers the Contact and Request-a-Quote forms.
# Get a free key at https://web3forms.com (enter the email you want submissions
# delivered to). Until this is set, the forms render a "not yet configured"
# notice instead of submitting.
PUBLIC_WEB3FORMS_KEY=
