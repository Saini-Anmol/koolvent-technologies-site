# Copy this file to `.env` and fill in the values.
# `.env` is gitignored — never commit real keys here.
# Production reads the same variables from Vercel → Settings → Environment Variables.

# Web3Forms access key — powers the Contact and Quote forms.
# Get a free key at https://web3forms.com (enter the email you want submissions
# delivered to). Until this is set, the forms render a friendly "email / call us"
# card instead of the working form.
PUBLIC_WEB3FORMS_KEY=
