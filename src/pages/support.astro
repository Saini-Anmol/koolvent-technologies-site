---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.tsx';
import Section from '@/components/Section.tsx';
import SectionHeading from '@/components/SectionHeading.tsx';
import Button from '@/components/Button.tsx';
import CtaBand from '@/components/CtaBand.tsx';
import { site } from '@/data/site';
import { faqs } from '@/data/faq';
import { isPlaceholder } from '@/lib/content';

const realFaqs = faqs.filter((f) => !isPlaceholder(f.answer));
const channelColours = ['bg-brand-50 text-brand-700', 'bg-emerald-50 text-emerald-700', 'bg-amber-50 text-amber-700'];
---

<BaseLayout
  title="Technical Support"
  description={`Technical support from ${site.name} — call, email or browse our FAQ for help with product selection, installation and after-sales queries.`}
>
  <PageHero
    eyebrow="Support"
    title="Technical Support"
    lead="Our engineering team is here to help — from product selection and submittals through installation and after-sales queries."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Technical Support' }]}
  />

  <!-- ── Support channels ──────────────────────────────────────────────── -->
  <Section bg="white" id="support-channels" spacing="tight">
    <SectionHeading
      eyebrow="Contact support"
      title="How to reach us"
      align="center"
    />
    <div class="mt-10 grid gap-6 sm:grid-cols-3">

      <!-- Phone -->
      <div class="flex flex-col items-start rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class={`flex h-11 w-11 items-center justify-center rounded-2xl ${channelColours[0]}`}>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd"
              d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 16.352V17.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5z"
              clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="mt-4 font-display text-base font-semibold text-slate-900">Phone</h3>
        <a href={site.contact.phoneHref} class="mt-1 text-sm font-medium text-brand-700 hover:text-brand-800">
          {site.contact.phone}
        </a>
        <p class="mt-2 text-xs text-slate-500">Selection assistance, installation guidance and troubleshooting.</p>
      </div>

      <!-- Email -->
      <div class="flex flex-col items-start rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class={`flex h-11 w-11 items-center justify-center rounded-2xl ${channelColours[1]}`}>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path d="M3 4a2 2 0 0 0-2 2v1.161l8.441 4.221a1.25 1.25 0 0 0 1.118 0L19 7.162V6a2 2 0 0 0-2-2H3z" />
            <path d="m19 8.839-7.77 3.885a2.75 2.75 0 0 1-2.46 0L1 8.839V14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.839z" />
          </svg>
        </div>
        <h3 class="mt-4 font-display text-base font-semibold text-slate-900">Email</h3>
        <a href={site.contact.emailHref} class="mt-1 text-sm font-medium text-brand-700 hover:text-brand-800">
          {site.contact.email}
        </a>
        <p class="mt-2 text-xs text-slate-500">Send us the product, sizes, quantity and timeline and we'll respond promptly.</p>
      </div>

      <!-- On-site -->
      <div class="flex flex-col items-start rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <div class={`flex h-11 w-11 items-center justify-center rounded-2xl ${channelColours[2]}`}>
          <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
            <path fill-rule="evenodd"
              d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5z"
              clip-rule="evenodd" />
          </svg>
        </div>
        <h3 class="mt-4 font-display text-base font-semibold text-slate-900">On-site support</h3>
        <p class="mt-1 text-sm text-slate-600">Commissioning assistance and specialist visits for larger projects.</p>
        <a href="/contact/" class="mt-3 text-sm font-semibold text-brand-700 hover:text-brand-800">Contact us to arrange →</a>
      </div>
    </div>
  </Section>

  <!-- ── FAQ ──────────────────────────────────────────────────────────── -->
  <Section bg="slate" id="faq">
    <div class="mx-auto max-w-3xl">
      <SectionHeading
        eyebrow="FAQ"
        title="Frequently asked questions"
        align="center"
      />

      <div class="mt-10 divide-y divide-slate-200 rounded-2xl border border-slate-200 bg-white overflow-hidden shadow-sm">
        {realFaqs.map((faq) => (
          <details class="group px-6 py-0">
            <summary class="flex cursor-pointer list-none items-center justify-between gap-4 py-4 text-sm font-semibold text-slate-900 hover:text-brand-700 focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-500 focus-visible:ring-inset [&::-webkit-details-marker]:hidden">
              <span>{faq.question}</span>
              <svg
                class="h-5 w-5 flex-none text-slate-400 transition-transform duration-200 group-open:rotate-180"
                viewBox="0 0 20 20"
                fill="currentColor"
                aria-hidden="true"
              >
                <path
                  fill-rule="evenodd"
                  d="M5.23 7.21a.75.75 0 0 1 1.06.02L10 11.168l3.71-3.938a.75.75 0 1 1 1.08 1.04l-4.25 4.5a.75.75 0 0 1-1.08 0l-4.25-4.5a.75.75 0 0 1 .02-1.06z"
                  clip-rule="evenodd"
                />
              </svg>
            </summary>
            <div class="pb-4 text-sm leading-relaxed text-slate-600">
              {faq.answer}
            </div>
          </details>
        ))}
      </div>

      <p class="mt-6 text-center text-sm text-slate-500">
        Can't find what you're looking for?{' '}
        <a href="/contact/" class="font-semibold text-brand-700 hover:text-brand-800 hover:underline">
          Contact us directly
        </a>
        .
      </p>
    </div>
  </Section>

  <!-- ── Documentation ─────────────────────────────────────────────────── -->
  <Section bg="white" id="resources" spacing="tight">
    <div class="mx-auto max-w-3xl">
      <SectionHeading eyebrow="Documentation" title="Datasheets & documentation" align="center">
        Product datasheets, installation and maintenance guides and compliance documentation are
        available on request — tailored to the product and configuration you're working with.
      </SectionHeading>
      <div class="mt-8 flex flex-wrap justify-center gap-3">
        <Button href="/quote/" variant="primary">Request a datasheet</Button>
        <Button href="/company-profile/" variant="ghost">Company profile →</Button>
      </div>
    </div>
  </Section>

  <CtaBand
    title="Need more help?"
    lead="Our engineering team is happy to assist with selection, installation and after-sales queries — get in touch and we'll respond promptly."
    primary={{ label: 'Contact us', href: '/contact/' }}
    secondary={{ label: 'Request a quote', href: '/quote/' }}
  />
</BaseLayout>
