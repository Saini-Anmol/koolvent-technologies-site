---
import type { GetStaticPaths } from 'astro';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.tsx';
import Section from '@/components/Section.tsx';
import SectionHeading from '@/components/SectionHeading.tsx';
import Button from '@/components/Button.tsx';
import SpecTable from '@/components/SpecTable.tsx';
import CtaBand from '@/components/CtaBand.tsx';
import { products, realSpecs, type Product } from '@/data/products';
import { accents } from '@/lib/accents';

export const getStaticPaths = (() => {
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}) satisfies GetStaticPaths;

interface Props {
  product: Product;
}

const { product } = Astro.props;
const a = accents[product.accent];
const related = products.filter((p) => p.slug !== product.slug);
const specs = realSpecs(product);
---

<BaseLayout title={product.name} description={product.summary}>
  <PageHero
    eyebrow="Product"
    title={product.name}
    lead={product.summary}
    breadcrumbs={[
      { label: 'Home', href: '/' },
      { label: 'Products', href: '/products/' },
      { label: product.name },
    ]}
  >
    <Button href="/quote/" size="lg" variant="gradient">Request a quote for this product</Button>
  </PageHero>

  <!-- Overview: image + intro + highlights -->
  <Section bg="white" id="overview">
    <div class="grid items-start gap-12 lg:grid-cols-2">
      <div class="reveal">
        <div class="relative">
          <div class={`absolute -inset-4 rounded-[2rem] bg-gradient-to-tr ${a.glow} blur-2xl`} aria-hidden="true"></div>
          <div class="relative overflow-hidden rounded-3xl bg-white shadow-xl ring-1 ring-slate-200">
            <div class={`h-1.5 w-full ${a.bar}`} aria-hidden="true"></div>
            <img src={product.image} alt={product.name} class="aspect-[4/3] w-full object-cover" />
          </div>
        </div>
      </div>

      <div class="reveal">
        <p class="text-lg leading-relaxed text-slate-600">{product.intro}</p>

        <h2 class="mt-8 font-display text-xl font-semibold text-slate-900">Key features</h2>
        <ul class="mt-4 space-y-3">
          {
            product.highlights.map((point) => (
              <li class="flex items-start gap-3 text-slate-700">
                <svg class={`mt-0.5 h-5 w-5 flex-none ${a.text}`} viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M16.7 5.3a1 1 0 0 1 0 1.4l-7.5 7.5a1 1 0 0 1-1.4 0L3.3 9.7a1 1 0 1 1 1.4-1.4l3.3 3.3 6.8-6.8a1 1 0 0 1 1.4 0z" clip-rule="evenodd" />
                </svg>
                <span>{point}</span>
              </li>
            ))
          }
        </ul>

        <div class="mt-8">
          <Button href="/quote/" variant="primary">Request a quote →</Button>
        </div>
      </div>
    </div>
  </Section>

  <!-- Applications -->
  <Section bg="slate" id="applications">
    <SectionHeading eyebrow="Applications" title="Where it's used" align="left">
      Typical installations where the {product.name} delivers reliable performance.
    </SectionHeading>
    <div class="mt-10 flex flex-wrap gap-3">
      {
        product.applications.map((app) => (
          <span class={`reveal inline-flex items-center rounded-full px-4 py-2 text-sm font-medium ${a.soft}`}>
            {app}
          </span>
        ))
      }
    </div>
  </Section>

  <!-- Specifications -->
  <Section bg="white" id="specifications">
    <SectionHeading eyebrow="Specifications" title="Technical data" align="left">
      {
        specs.length > 0
          ? 'Key technical parameters for this product family.'
          : 'Detailed specifications are configured per project.'
      }
    </SectionHeading>

    {
      specs.length > 0 ? (
        <div class="reveal mt-10 max-w-2xl">
          <SpecTable rows={specs} />
        </div>
      ) : (
        <div class="reveal mt-10 max-w-2xl rounded-2xl border border-slate-200 bg-slate-50 p-8">
          <p class="text-slate-700">
            Sizes, materials, connections and ratings for the {product.name} are
            confirmed against your project requirements. Request a quote and our
            engineers will provide a full technical datasheet.
          </p>
          <div class="mt-5">
            <Button href="/quote/" variant="primary">Request a datasheet & quote</Button>
          </div>
        </div>
      )
    }

    {
      specs.length > 0 && (
        <p class="mt-6 text-sm text-slate-500">
          Need a specific configuration?{' '}
          <a href="/quote/" class={`font-semibold ${a.text}`}>Request a quote</a> and our engineers will size it to your requirements.
        </p>
      )
    }
  </Section>

  <!-- Related products -->
  <Section bg="slate" id="related">
    <SectionHeading eyebrow="Other products" title="More from Koolvent" align="center" />
    <div class="mt-10 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {
        related.map((p) => {
          const ra = accents[p.accent];
          return (
            <a
              href={`/products/${p.slug}/`}
              class={`reveal group flex items-center gap-4 rounded-2xl border border-slate-200 bg-white p-4 ring-1 ring-transparent transition-all hover:shadow-md ${ra.ring}`}
            >
              <div class="h-16 w-16 flex-none overflow-hidden rounded-xl bg-slate-50">
                <img src={p.image} alt={p.name} loading="lazy" class="h-full w-full object-cover transition-transform duration-300 group-hover:scale-105" />
              </div>
              <div class="min-w-0">
                <p class={`font-display font-semibold text-slate-900 transition-colors ${ra.textGroupHover}`}>{p.name}</p>
                <p class="mt-0.5 text-sm leading-snug text-slate-500 line-clamp-2">{p.summary}</p>
              </div>
              <svg class={`ml-auto h-5 w-5 flex-none text-slate-300 transition-transform group-hover:translate-x-0.5`} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
              </svg>
            </a>
          );
        })
      }
    </div>
  </Section>

  <CtaBand
    title={`Interested in the ${product.name}?`}
    lead="Send us your project requirements and our engineers will confirm sizing, materials and delivery — or design a custom variant."
    primary={{ label: 'Request a quote', href: '/quote/' }}
    secondary={{ label: 'Contact us', href: '/contact/' }}
  />
</BaseLayout>
