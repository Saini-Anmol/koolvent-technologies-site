---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.tsx';
import SectionHeading from '@/components/SectionHeading.tsx';
import ProductCard from '@/components/ProductCard.tsx';
import CapabilityGrid from '@/components/CapabilityGrid.tsx';
import CtaBand from '@/components/CtaBand.tsx';
import { products } from '@/data/products';
import { site } from '@/data/site';

const cityName = site.location.split(',')[0];

const aboutPoints = [
  'Advanced HVAC systems for sustainable, energy-efficient buildings',
  'Precision fluid-control fittings for reliable industrial operation',
  'Custom-engineered assemblies for large-scale infrastructure',
];

const industries = [
  'Commercial buildings',
  'Healthcare',
  'Data centres',
  'Hospitality',
  'Manufacturing',
  'Infrastructure',
];

const heroProduct = products[0];
---

<BaseLayout>
  <!-- ─────────────────────────── Hero ─────────────────────────── -->
  <section class="relative isolate overflow-hidden bg-slate-950 text-white">
    <div class="bg-grid absolute inset-0 opacity-60" aria-hidden="true"></div>
    <div class="absolute -left-40 top-0 h-[34rem] w-[34rem] rounded-full bg-brand-600/30 blur-3xl" aria-hidden="true"></div>
    <div class="absolute right-0 top-1/4 h-80 w-80 translate-x-1/3 rounded-full bg-emerald-500/20 blur-3xl" aria-hidden="true"></div>
    <div class="absolute bottom-0 left-1/3 h-72 w-72 translate-y-1/3 rounded-full bg-amber-400/15 blur-3xl" aria-hidden="true"></div>

    <div class="relative mx-auto grid max-w-7xl gap-14 px-4 py-20 sm:px-6 lg:grid-cols-12 lg:items-center lg:gap-10 lg:px-8 lg:py-28">
      <div class="lg:col-span-7">
        <p class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-3 py-1 text-xs font-medium uppercase tracking-wider text-brand-200">
          <span class="h-1.5 w-1.5 rounded-full bg-emerald-400"></span>
          HVAC &amp; Fluid-Control Components · Est. {site.foundedYear}
        </p>
        <h1 class="mt-6 text-4xl font-bold leading-[1.08] tracking-tight text-white sm:text-5xl lg:text-[3.4rem]">
          Components that make every HVAC system
          <span class="bg-gradient-to-r from-brand-300 via-emerald-300 to-amber-300 bg-clip-text text-transparent">
            run cleaner, quieter, longer
          </span>
        </h1>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-slate-300">
          {site.name} engineers and manufactures the suction guides, pressure
          vessels, hot water generators and valve kits that keep industrial,
          commercial and infrastructure systems running — certified,
          configurable and built for the field.
        </p>
        <div class="mt-8 flex flex-wrap gap-3">
          <Button href="/products/" size="lg" variant="gradient">Explore products</Button>
          <Button href="/quote/" size="lg" variant="outline-dark">Request a quote</Button>
        </div>
        <p class="mt-10 text-xs font-semibold uppercase tracking-wider text-slate-500">
          Trusted across
        </p>
        <div class="mt-3 flex flex-wrap gap-2">
          {
            industries.map((name) => (
              <span class="rounded-full border border-white/10 bg-white/[0.04] px-3 py-1 text-xs font-medium text-slate-300">
                {name}
              </span>
            ))
          }
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="relative mx-auto max-w-md">
          <div class="absolute -inset-4 rounded-[2rem] bg-gradient-to-tr from-brand-500/30 via-emerald-400/15 to-amber-300/10 blur-2xl" aria-hidden="true"></div>
          <div class="relative overflow-hidden rounded-3xl bg-white shadow-2xl ring-1 ring-white/10">
            <div class="h-1.5 w-full bg-brand-500" aria-hidden="true"></div>
            <img src={heroProduct.image} alt={heroProduct.name} class="aspect-[4/3] w-full object-cover" />
            <div class="flex items-center justify-between border-t border-slate-100 px-5 py-4">
              <div>
                <p class="text-xs font-semibold uppercase tracking-wider text-brand-600">Featured</p>
                <p class="mt-0.5 font-display text-base font-semibold text-slate-900">{heroProduct.name}</p>
              </div>
              <a href={`/products/${heroProduct.slug}/`} class="text-sm font-semibold text-brand-700 hover:text-brand-800">View →</a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ──────────────────────── Capabilities ─────────────────────── -->
  <section class="border-b border-slate-100 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-16 sm:px-6 lg:px-8 lg:py-20">
      <CapabilityGrid />
    </div>
  </section>

  <!-- ────────────────────────── About ──────────────────────────── -->
  <section id="about" class="scroll-mt-20 bg-slate-50">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
      <div class="grid items-center gap-12 lg:grid-cols-2">
        <div class="reveal">
          <p class="text-sm font-semibold uppercase tracking-wider text-brand-600">About Koolvent</p>
          <h2 class="mt-2 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
            HVAC and fluid-control expertise, engineered for the field
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-slate-600">
            Founded in {site.foundedYear} in {site.location}, {site.name} builds
            high-quality, engineered components for industrial, commercial and
            infrastructure projects. Our focus is simple: reliable, certified,
            high-performance products that hold up to the most demanding client
            requirements — from fluid dynamics to thermal regulation.
          </p>
          <ul class="mt-6 space-y-3">
            {
              aboutPoints.map((point, i) => {
                const dot = ['bg-brand-500', 'bg-emerald-500', 'bg-amber-400'][i % 3];
                return (
                  <li class="flex items-start gap-3 text-slate-700">
                    <span class={`mt-2 h-2 w-2 flex-none rounded-full ${dot}`} aria-hidden="true"></span>
                    <span>{point}</span>
                  </li>
                );
              })
            }
          </ul>
          <div class="mt-8 flex flex-wrap gap-3">
            <Button href="/about/" variant="primary">More about us</Button>
            <Button href="/company-profile/" variant="ghost">Company profile →</Button>
          </div>
        </div>

        <!-- Colourful abstract panel (no stock photos) -->
        <div class="reveal">
          <div class="relative aspect-[4/3] w-full overflow-hidden rounded-3xl bg-gradient-to-br from-brand-50 via-white to-emerald-50 ring-1 ring-slate-200">
            <div class="absolute -left-10 -top-10 h-48 w-48 rounded-full bg-brand-400/30 blur-2xl" aria-hidden="true"></div>
            <div class="absolute right-0 top-1/3 h-40 w-40 rounded-full bg-emerald-400/25 blur-2xl" aria-hidden="true"></div>
            <div class="absolute bottom-0 left-1/4 h-44 w-44 rounded-full bg-amber-300/30 blur-2xl" aria-hidden="true"></div>
            <div class="absolute inset-0 flex items-center justify-center p-8">
              <div class="grid w-full max-w-sm grid-cols-2 gap-4">
                <div class="rounded-2xl bg-white/80 p-4 shadow-sm ring-1 ring-slate-200 backdrop-blur">
                  <div class="h-2 w-10 rounded-full bg-brand-500"></div>
                  <p class="mt-3 font-display text-2xl font-bold text-slate-900">{products.length}</p>
                  <p class="text-xs text-slate-500">product families</p>
                </div>
                <div class="rounded-2xl bg-white/80 p-4 shadow-sm ring-1 ring-slate-200 backdrop-blur">
                  <div class="h-2 w-10 rounded-full bg-emerald-500"></div>
                  <p class="mt-3 font-display text-2xl font-bold text-slate-900">{site.foundedYear}</p>
                  <p class="text-xs text-slate-500">established in {cityName}</p>
                </div>
                <div class="col-span-2 rounded-2xl bg-white/80 p-4 shadow-sm ring-1 ring-slate-200 backdrop-blur">
                  <div class="flex gap-1.5">
                    <span class="h-2 w-2 rounded-full bg-brand-500"></span>
                    <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
                    <span class="h-2 w-2 rounded-full bg-amber-400"></span>
                    <span class="h-2 w-2 rounded-full bg-rose-400"></span>
                  </div>
                  <p class="mt-3 text-sm font-medium text-slate-700">
                    Engineered, certified and configured to your project — backed by real engineering support.
                  </p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ───────────────────────── Products ────────────────────────── -->
  <section id="products" class="scroll-mt-20 bg-white">
    <div class="mx-auto max-w-7xl px-4 py-20 sm:px-6 lg:px-8 lg:py-24">
      <SectionHeading eyebrow="Product portfolio" title="What we make" align="center">
        Four core product families — each configurable to your project
        requirements.
      </SectionHeading>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {products.map((product) => <ProductCard product={product} />)}
      </div>

      <div class="mt-12 text-center">
        <Button href="/products/" variant="ghost">View all products →</Button>
      </div>
    </div>
  </section>

  <!-- ──────────────────────────── CTA ──────────────────────────── -->
  <CtaBand
    title="Have a project? Let's talk specs."
    lead="Send us your requirements or schedule and our engineers will help you select — or design — the right component."
    primary={{ label: 'Request a quote', href: '/quote/' }}
    secondary={{ label: 'Contact us', href: '/contact/' }}
  />
</BaseLayout>
