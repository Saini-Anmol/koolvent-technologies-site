---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.tsx';
import Section from '@/components/Section.tsx';
import ContactForm from '@/components/ContactForm.tsx';
import { products } from '@/data/products';
import { site } from '@/data/site';
---

<BaseLayout
  title="Request a Quote"
  description={`Request a tailored quote from ${site.name} for suction guides, pressure vessels, hot water generators or valve kits. Tell us your product, spec, quantity and timeline.`}
>
  <PageHero
    eyebrow="Sales"
    title="Request a Quote"
    lead="Tell us what you need — product family, sizes or spec, quantity, project location and your target timeline. Our engineering team will respond with a tailored proposal."
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Request a Quote' }]}
  />

  <Section bg="white" id="quote-body">
    <div class="grid gap-12 lg:grid-cols-3 lg:gap-16">

      <!-- ── Main: quote form ───────────────────────────────────────── -->
      <div class="lg:col-span-2">
        <h2 class="mb-6 font-display text-xl font-bold text-slate-900">Your enquiry</h2>
        <ContactForm kind="quote" />
      </div>

      <!-- ── Side: what happens next + product links ────────────────── -->
      <div class="space-y-10">

        <!-- What happens next -->
        <div class="rounded-xl border border-slate-200 bg-slate-50 p-6">
          <h3 class="font-display text-base font-semibold text-slate-900">What happens next</h3>
          <ol class="mt-4 space-y-4">
            {[
              {
                step: '1',
                heading: 'We receive your enquiry',
                body: 'Your message goes directly to our sales and engineering team.',
              },
              {
                step: '2',
                heading: 'Technical review',
                body: 'We check your requirements against our product range and flag any questions.',
              },
              {
                step: '3',
                heading: 'Proposal sent',
                body: 'You receive a detailed quotation with sizing, pricing and lead time for your requirement.',
              },
              {
                step: '4',
                heading: 'Q&A and order',
                body: "We're happy to discuss the proposal and refine it before you place the order.",
              },
            ].map((item) => (
              <li class="flex gap-3">
                <span class="flex h-6 w-6 flex-none items-center justify-center rounded-full bg-brand-600 text-xs font-bold text-white">
                  {item.step}
                </span>
                <div>
                  <p class="text-sm font-semibold text-slate-900">{item.heading}</p>
                  <p class="mt-0.5 text-sm text-slate-600">{item.body}</p>
                </div>
              </li>
            ))}
          </ol>

          <p class="mt-5 text-xs text-slate-500">
            We aim to respond to every enquiry promptly during business hours.
          </p>
        </div>

        <!-- Product families -->
        <div>
          <h3 class="font-display text-base font-semibold text-slate-900">Our product families</h3>
          <p class="mt-1 text-sm text-slate-600">
            Not sure which product fits? Browse the details first.
          </p>
          <ul class="mt-4 space-y-2">
            {products.map((p) => (
              <li>
                <a
                  href={`/products/${p.slug}/`}
                  class="group flex items-center gap-2 text-sm text-brand-700 hover:text-brand-900"
                >
                  <svg
                    class="h-4 w-4 flex-none opacity-60 transition group-hover:opacity-100"
                    viewBox="0 0 20 20"
                    fill="currentColor"
                    aria-hidden="true"
                  >
                    <path
                      fill-rule="evenodd"
                      d="M3 10a.75.75 0 0 1 .75-.75h10.638L10.23 5.29a.75.75 0 1 1 1.04-1.08l5.5 5.25a.75.75 0 0 1 0 1.08l-5.5 5.25a.75.75 0 1 1-1.04-1.08l4.158-3.96H3.75A.75.75 0 0 1 3 10z"
                      clip-rule="evenodd"
                    />
                  </svg>
                  <span>
                    <span class="font-medium">{p.name}</span>
                    <span class="ml-1 text-slate-500">— {p.summary}</span>
                  </span>
                </a>
              </li>
            ))}
          </ul>
          <a
            href="/products/"
            class="mt-4 inline-block text-sm font-semibold text-brand-700 hover:text-brand-900 hover:underline"
          >
            View all products →
          </a>
        </div>

        <!-- Contact fallback -->
        <div class="rounded-xl border border-slate-200 bg-white p-6 text-sm text-slate-600">
          <p class="font-semibold text-slate-900">Prefer to call or email?</p>
          <p class="mt-1">
            Reach us at{' '}
            <a href={site.contact.phoneHref} class="text-brand-700 hover:underline">
              {site.contact.phone}
            </a>{' '}
            or{' '}
            <a href={site.contact.emailHref} class="text-brand-700 hover:underline">
              {site.contact.email}
            </a>
            .
          </p>
        </div>
      </div>
    </div>
  </Section>
</BaseLayout>
