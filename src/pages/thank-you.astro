---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Button from '@/components/Button.tsx';
import { site } from '@/data/site';
---

<BaseLayout title="Thank you" description="Your message has been received." noindex>
  <section class="mx-auto flex max-w-2xl flex-col items-center px-4 py-24 text-center sm:px-6 lg:py-32">
    <div class="flex h-16 w-16 items-center justify-center rounded-full bg-brand-50 text-brand-600">
      <svg class="h-8 w-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
        <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
      </svg>
    </div>
    <h1 class="mt-6 text-3xl font-bold tracking-tight text-slate-900 sm:text-4xl">
      Thanks — we've got your message
    </h1>
    <p class="mt-4 text-lg leading-relaxed text-slate-600">
      A member of our team will get back to you shortly. If it's urgent, call us
      on <a href={site.contact.phoneHref} class="font-semibold text-brand-700 hover:underline">{site.contact.phone}</a>.
    </p>
    <div class="mt-8 flex flex-wrap justify-center gap-3">
      <Button href="/" variant="primary">Back to home</Button>
      <Button href="/products/" variant="ghost">Browse products →</Button>
    </div>
  </section>
</BaseLayout>
