---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.tsx';
import Section from '@/components/Section.tsx';
import ContactForm from '@/components/ContactForm.tsx';
import { site } from '@/data/site';
---

<BaseLayout
  title="Contact Us"
  description={`Get in touch with ${site.name} — call, email or send a message and our team will respond promptly.`}
>
  <PageHero
    eyebrow="Get in touch"
    title="Contact Us"
    lead={`We'd love to hear about your project. Call or email us directly, or use the form and we'll get back to you as soon as possible.`}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Contact' }]}
  />

  <Section bg="white" id="contact-body">
    <div class="grid gap-12 lg:grid-cols-5 lg:gap-16">

      <!-- ── Left: contact details ──────────────────────────────────── -->
      <div class="lg:col-span-2 space-y-8">
        <div>
          <h2 class="text-xl font-bold text-slate-900 font-display">Contact details</h2>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">
            Reach us directly or use the form. Our team is based in {site.location}.
          </p>
        </div>

        <!-- Address -->
        <div class="flex gap-3">
          <div class="mt-1 flex-none text-brand-600">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd"
                d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.309-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 9.19 9.19 0 0 0 .758.433c.118.058.208.098.272.127l.018.008.006.003zM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5z"
                clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900">Address</p>
            <p class="mt-0.5 text-sm text-slate-600">{site.contact.address}</p>
            <p class="text-sm text-slate-500">GST: {site.gst}</p>
          </div>
        </div>

        <!-- Phone -->
        <div class="flex gap-3">
          <div class="mt-1 flex-none text-brand-600">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd"
                d="M2 3.5A1.5 1.5 0 0 1 3.5 2h1.148a1.5 1.5 0 0 1 1.465 1.175l.716 3.223a1.5 1.5 0 0 1-1.052 1.767l-.933.267c-.41.117-.643.555-.48.95a11.542 11.542 0 0 0 6.254 6.254c.395.163.833-.07.95-.48l.267-.933a1.5 1.5 0 0 1 1.767-1.052l3.223.716A1.5 1.5 0 0 1 18 16.352V17.5a1.5 1.5 0 0 1-1.5 1.5H15c-1.149 0-2.263-.15-3.326-.43A13.022 13.022 0 0 1 2.43 8.326 13.019 13.019 0 0 1 2 5V3.5z"
                clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900">Phone</p>
            <a href={site.contact.phoneHref} class="mt-0.5 text-sm text-brand-700 hover:text-brand-800">
              {site.contact.phone}
            </a>
          </div>
        </div>

        <!-- Email -->
        <div class="flex gap-3">
          <div class="mt-1 flex-none text-brand-600">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path d="M3 4a2 2 0 0 0-2 2v1.161l8.441 4.221a1.25 1.25 0 0 0 1.118 0L19 7.162V6a2 2 0 0 0-2-2H3z" />
              <path d="m19 8.839-7.77 3.885a2.75 2.75 0 0 1-2.46 0L1 8.839V14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V8.839z" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900">Email</p>
            <a href={site.contact.emailHref} class="mt-0.5 text-sm text-brand-700 hover:text-brand-800">
              {site.contact.email}
            </a>
          </div>
        </div>

        <!-- Business hours -->
        <div class="flex gap-3">
          <div class="mt-1 flex-none text-brand-600">
            <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
              <path fill-rule="evenodd"
                d="M10 18a8 8 0 1 0 0-16 8 8 0 0 0 0 16zm.75-13a.75.75 0 0 0-1.5 0v5c0 .414.336.75.75.75h4a.75.75 0 0 0 0-1.5h-3.25V5z"
                clip-rule="evenodd" />
            </svg>
          </div>
          <div>
            <p class="text-sm font-semibold text-slate-900">Business hours</p>
            <p class="mt-0.5 text-sm text-slate-600">Email and the form reach us any time — we respond promptly during business hours.</p>
          </div>
        </div>

        <!-- Location -->
        <a
          href="https://www.google.com/maps/search/?api=1&query=Koolvent+Technologies+Noida"
          target="_blank"
          rel="noopener noreferrer"
          class="group block overflow-hidden rounded-2xl border border-slate-200 bg-gradient-to-br from-brand-50 via-white to-emerald-50 transition hover:shadow-md"
        >
          <div class="relative flex h-52 items-center justify-center">
            <div class="absolute -left-6 -top-6 h-32 w-32 rounded-full bg-brand-300/30 blur-2xl" aria-hidden="true"></div>
            <div class="absolute bottom-0 right-0 h-32 w-32 rounded-full bg-amber-300/30 blur-2xl" aria-hidden="true"></div>
            <div class="relative flex flex-col items-center gap-2 text-center">
              <span class="flex h-12 w-12 items-center justify-center rounded-2xl bg-white text-brand-600 shadow-sm ring-1 ring-slate-200">
                <svg class="h-6 w-6" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path fill-rule="evenodd" d="M11.54 22.351l.07.04.028.016a.76.76 0 0 0 .723 0l.028-.015.071-.041a16.975 16.975 0 0 0 1.144-.742 19.58 19.58 0 0 0 2.683-2.282c1.944-1.99 3.963-4.98 3.963-8.827a8.25 8.25 0 0 0-16.5 0c0 3.846 2.02 6.837 3.963 8.827a19.58 19.58 0 0 0 2.682 2.282 16.975 16.975 0 0 0 1.145.742zM12 13.5a3 3 0 1 0 0-6 3 3 0 0 0 0 6z" clip-rule="evenodd" />
                </svg>
              </span>
              <p class="text-sm font-semibold text-slate-900">{site.location}</p>
              <p class="text-xs font-semibold text-brand-700 group-hover:underline">Open in Google Maps →</p>
            </div>
          </div>
        </a>

        <!-- Shortcut links -->
        <div class="flex flex-col gap-2 border-t border-slate-100 pt-6 text-sm">
          <p class="font-semibold text-slate-900">Other ways we can help</p>
          <a href="/quote/" class="text-brand-700 hover:text-brand-800 hover:underline">
            Request a quote →
          </a>
          <a href="/support/" class="text-brand-700 hover:text-brand-800 hover:underline">
            Technical support & FAQ →
          </a>
        </div>
      </div>

      <!-- ── Right: contact form ────────────────────────────────────── -->
      <div class="lg:col-span-3">
        <h2 class="text-xl font-bold text-slate-900 font-display mb-6">Send us a message</h2>
        <ContactForm />
      </div>
    </div>
  </Section>
</BaseLayout>
