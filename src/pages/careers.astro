---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageHero from '@/components/PageHero.tsx';
import Section from '@/components/Section.tsx';
import SectionHeading from '@/components/SectionHeading.tsx';
import Button from '@/components/Button.tsx';
import CtaBand from '@/components/CtaBand.tsx';
import { site } from '@/data/site';
import { openings, benefits, howToApply } from '@/data/careers';
import { isPlaceholder } from '@/lib/content';
import { accentOrder, accents } from '@/lib/accents';

const realOpenings = openings.filter((o) => !isPlaceholder(o.summary));
---

<BaseLayout
  title="Careers"
  description={`Join ${site.name} — a growing HVAC and fluid-control manufacturer based in ${site.location}. Explore open roles and find out how to apply.`}
>
  <PageHero
    eyebrow="Join us"
    title="Careers at Koolvent"
    lead={`We're building a team of engineers, sales professionals and operations specialists who take pride in making high-quality industrial products. Based in ${site.location}.`}
    breadcrumbs={[{ label: 'Home', href: '/' }, { label: 'Careers' }]}
  />

  <!-- ── Culture & benefits ─────────────────────────────────────────────── -->
  <Section bg="white" id="culture">
    <SectionHeading
      eyebrow="Why Koolvent"
      title="Why work here"
      align="center"
    >
      We are a young, engineering-led company with ambitious plans. Here is what
      we offer the people who join us.
    </SectionHeading>

    <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {benefits.map((b, i) => (
        <div class="reveal rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
          <div class={`h-1.5 w-10 rounded-full ${accents[accentOrder[i % accentOrder.length]].bar}`}></div>
          <h3 class="mt-4 font-display text-base font-semibold text-slate-900">{b.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-slate-600">{b.description}</p>
        </div>
      ))}
    </div>
  </Section>

  <!-- ── Current openings ───────────────────────────────────────────────── -->
  <Section bg="slate" id="openings">
    <SectionHeading
      eyebrow="Open roles"
      title="Current openings"
      align="left"
    />

    {realOpenings.length > 0 ? (
      <div class="mt-10 space-y-4">
        {realOpenings.map((role) => (
          <div class="reveal rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
            <div class="flex flex-col gap-4 sm:flex-row sm:items-start sm:justify-between">
              <div class="flex-1">
                <h3 class="font-display text-lg font-semibold text-slate-900">{role.title}</h3>
                <div class="mt-1 flex flex-wrap items-center gap-3">
                  <span class="inline-flex items-center gap-1 text-xs text-slate-500">
                    <svg class="h-3.5 w-3.5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
                      <path fill-rule="evenodd" d="M9.69 18.933l.003.001C9.89 19.02 10 19 10 19s.11.02.309-.066l.002-.001.006-.003.018-.008a5.741 5.741 0 0 0 .281-.14c.186-.096.446-.24.757-.433.62-.384 1.445-.966 2.274-1.765C15.302 14.988 17 12.493 17 9A7 7 0 1 0 3 9c0 3.492 1.698 5.988 3.355 7.584a13.731 13.731 0 0 0 2.273 1.765 9.19 9.19 0 0 0 .758.433c.118.058.208.098.272.127l.018.008.006.003zM10 11.25a2.25 2.25 0 1 0 0-4.5 2.25 2.25 0 0 0 0 4.5z" clip-rule="evenodd" />
                    </svg>
                    {role.location}
                  </span>
                  <span class="inline-flex items-center rounded-full bg-brand-50 px-2.5 py-0.5 text-xs font-medium text-brand-700 ring-1 ring-inset ring-brand-200">
                    {role.type}
                  </span>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-slate-600">{role.summary}</p>
              </div>
              <div class="flex-none">
                <a
                  href={`${site.contact.emailHref}?subject=Application: ${encodeURIComponent(role.title)}`}
                  class="inline-flex items-center justify-center rounded-md bg-brand-600 px-4 py-2 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-600"
                >
                  Apply
                </a>
              </div>
            </div>
          </div>
        ))}
      </div>
    ) : (
      /* Empty-state — shown when openings array is empty */
      <div class="mt-10 rounded-xl border border-slate-200 bg-white p-8 text-center">
        <p class="font-display text-base font-semibold text-slate-900">No open roles right now</p>
        <p class="mt-2 text-sm text-slate-600">
          We're always glad to hear from talented people. Send your CV to{' '}
          <a href={site.contact.emailHref} class="text-brand-700 hover:underline font-semibold">
            {site.contact.email}
          </a>{' '}
          and we'll be in touch when a suitable opportunity arises.
        </p>
      </div>
    )}
  </Section>

  <!-- ── How to apply ───────────────────────────────────────────────────── -->
  <Section bg="white" id="how-to-apply" spacing="tight">
    <div class="mx-auto max-w-2xl">
      <SectionHeading
        eyebrow="Applications"
        title="How to apply"
        align="center"
      />
      <p class="mt-5 text-center text-sm leading-relaxed text-slate-600">{howToApply}</p>
      <div class="mt-6 flex flex-wrap justify-center gap-3">
        <a
          href={site.contact.emailHref}
          class="inline-flex items-center justify-center rounded-md bg-brand-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm transition-colors hover:bg-brand-700 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-600"
        >
          Email your CV
        </a>
        <a
          href="/contact/"
          class="inline-flex items-center justify-center rounded-md border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-700 shadow-sm transition-colors hover:bg-slate-50 focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-600"
        >
          General enquiry
        </a>
      </div>
    </div>
  </Section>

  <CtaBand
    title="Interested in what we do?"
    lead="Learn more about the products we build and the company behind them."
    primary={{ label: 'Our products', href: '/products/' }}
    secondary={{ label: 'About Koolvent', href: '/about/' }}
  />
</BaseLayout>
